  },
  "keywords": [
    "HTML",
    "table",
    "json",
    "ajax"
  ],
  "files": [
    "src/**/*.{css,js,svg}",
    "docs/**/*.{md,png,jpeg,webp,svg}"
  ],
  "devDependencies": {
