{
  "name": "@massimo-cassandro/json-table",
  "version": "0.1.0",
  "description": "HTML table builder from json data",
  "main": "dist/jsonTable.esm.js",
  "author": "Massimo Cassandro",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/massimo-cassandro/json-table/issues"
  },
  "scripts": {

    "launch-json-demo-server": "json-server ./demo/demo-data/json-ajax-demo.json --port 3004 ",
    "webpack DEV": "npm run launchChrome && NODE_ENV=development webpack serve --config ./demo/webpack.config.mjs ",
    "upd vers": "npx update-version",
    "upd@m": "npx upd@m",
    "launchChrome": "open -n -a 'Google Chrome' --args --profile-directory='Profile 3' http://localhost:5700/"
  },
