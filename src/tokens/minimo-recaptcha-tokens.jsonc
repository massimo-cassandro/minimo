{
  "recaptcha": {
    "alert": {
      
      "overlay": {
        "color": {
          "$type": "color",
          "$value": "rgb(0 0 0 / .5)"
        },
      },

      "background": {
        "color": {
          "$type": "color",
          "$value": "#000"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": "#fff"
      },
    }
  }
}
