{
  "alert": {
    "border": {
      "radius": {
        "$value": "{radius.md}",
        "$type": "dimension"
      },
    },

    "drop-shadow": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": 0,
          "offsetY": 0,
          "blur": "8px",
          "spread": 0,
          "color": "oklch(0 0 0 / 0.5)"
        }
      ]
    }
  }
}
