{
  "__help": "https://code.visualstudio.com/docs/languages/jsconfig",
  "compilerOptions": {
    "target": "es2023",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": false,
    "module": "ES6",
    "paths": {
      "@demo/*": ["./demo/*"],
      "@src/*": ["./src/*"],
      "@minimo/*": ["./src/*"]
    }



  },
  "exclude": ["node_modules", "dist", "docs", "build", "public"]
}
